@page
@model LigaBotonera.Pages.Index1Model
@{
}

<style>
    #indicator .spinner-icon {
        display: none;
    }

    #indicator .htmx-request .lupa-icon {
        display: none;
    }

    #indicator .htmx-request .spinner-icon {
        display: block;
    }
</style>

<input type="text" class="text-sm rounded-lg border border-slate-200 dark:border-emerald-600 bg-slate-50 dark:bg-emerald-700 text-slate-800 dark:text-white px-2 py-1 focus:outline-none focus:ring-2 focus:ring-field-green-500" />
<br />

<div x-data="lookupComponent"
     x-on:htmx:after-on-load.window="showGrid = document.getElementById('grid-container').innerHTML.trim() !== ''"
     class="w-full space-y-2">
    <div>
        <label class="block text-sm font-medium text-slate-700 dark:text-white">Produto:</label>
        <div class="relative flex items-center">
            <input type="text"
                   name="query"
                   x-model="lookupText"
                   x-on:input="onInput()"
                   x-on:blur="onBlur()"
                   x-on:keydown.enter.prevent="onEnter()"
                   x-on:click.away="showGrid=false"
                   x-on:htmx:config-request="onConfigRequest($event)"
                   hx-get="?handler=BuscarItens"
                   hx-trigger="keyup changed delay:300ms"
                   hx-target="#grid-container"
                   hx-indicator="#indicator"
                   class="text-sm w-full rounded-lg border border-slate-200 dark:border-emerald-600 bg-slate-50 dark:bg-emerald-700 text-slate-800 dark:text-white px-2 py-1 focus:outline-none focus:ring-2 focus:ring-field-green-500"
            />
            <div id="indicator" class="absolute right-2 flex items-center justify-center pointer-events-none">
                <svg class="h-4 w-4 text-slate-400 lupa-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
                <svg class="animate-spin h-4 w-4 text-emerald-500 spinner-icon hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
            </div>
        </div>
        <input type="hidden" name="lookup-id" id="lookup-id" />
    </div>
    <div id="grid-container"
         x-show="showGrid"
         class="absolute left-0 right-0 z-[100]"
         style="display: none;"
         x-transition>
    </div>
</div>

<br />
<input type="text" class="text-sm rounded-lg border border-slate-200 dark:border-emerald-600 bg-slate-50 dark:bg-emerald-700 text-slate-800 dark:text-white px-2 py-1 focus:outline-none focus:ring-2 focus:ring-field-green-500" />

<script>
    document.addEventListener('alpine:init', () => {
        Alpine.data('lookupComponent', () => ({
            lookupText: '',
            lastSearch: '',
            showGrid: false,

            onInput() {
                if (this.lookupText !== this.lastSearch) {
                    document.getElementById('lookup-id').value = '';
                }
                if (this.lookupText.trim().length === 0) {
                    this.showGrid = false;
                    document.getElementById('grid-container').innerHTML = '';
                }
                this.lastSearch = '';
            },

            onBlur() {
                setTimeout(() => {
                    if (!document.getElementById('lookup-id').value) {
                        this.lookupText = '';
                    }
                    document.getElementById('grid-container').innerHTML = '';
                    this.showGrid = false;
                }, 200);
            },

            onEnter() {
                const singleRow = document.getElementById('single-row');
                if (singleRow) {
                    const id = singleRow.getAttribute('data-id');
                    const name = singleRow.getAttribute('data-name');
                    this.onSelectedItem(name, id);
                }
            },

            onConfigRequest(event) {
                if (this.lookupText === this.lastSearch) {
                    event.preventDefault();
                }
            },

            onSelectedItem(nome, id) {
                this.lookupText = nome;
                this.lastSearch = nome;
                document.getElementById('lookup-id').value = id;
                document.getElementById('grid-container').innerHTML = '';
                this.showGrid = false;
            }
        }));
    });
</script>