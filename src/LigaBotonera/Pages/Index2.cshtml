@page
@model LigaBotonera.Pages.Index2Model
@{
}

<input type="text" class="text-sm rounded-lg border border-slate-200 dark:border-emerald-600 bg-slate-50 dark:bg-emerald-700 text-slate-800 dark:text-white px-2 py-1 focus:outline-none focus:ring-2 focus:ring-field-green-500" />
<br />

<div x-data="bindLookup('@Model.ProdutoLookup.Id', window.produtoMapping)">

    <partial name="@Shared.PartialViewId.Lookup2" model='@Model.ProdutoLookup' />


    <br />
    <input type="text" x-model="categoriaNome" class="text-sm rounded-lg border border-slate-200 dark:border-emerald-600 bg-slate-50 dark:bg-emerald-700 text-slate-800 dark:text-white px-2 py-1 focus:outline-none focus:ring-2 focus:ring-field-green-500" />

</div>

<div x-data="bindLookup('@Model.ClienteLookup.Id', window.clienteMapping)">

    <partial name="@Shared.PartialViewId.Lookup2" model='@Model.ClienteLookup' />

    <br />
    <input type="text" x-model="idade" class="text-sm rounded-lg border border-slate-200 dark:border-emerald-600 bg-slate-50 dark:bg-emerald-700 text-slate-800 dark:text-white px-2 py-1 focus:outline-none focus:ring-2 focus:ring-field-green-500" />
</div>

@section Scripts {
    <script  src="~/js/lookup2.js"></script>
    <script>
        window.produtoMapping = {
            categoriaId: 'CategoriaId',
            categoriaNome: 'CategoriaNome'
        };

        window.clienteMapping = {
            idade: { field: 'Idade', default: 0 }
        };
    </script>
}